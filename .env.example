# =========================================================================
# AI Study Assistant - Environment Variables Configuration
# Copy this file to a new file named '.env' in the same folder and fill in values.
# =========================================================================

# --- Supabase Database (Used by React Frontend & Node Backend) ---
# Pre-fixed with VITE_ to make them visible to the Vite client bundler.
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Supabase Service Role Key (Used only by Node Backend) ---
# Optional: Can be used for high-privilege queries that bypass Row Level Security.
# If left blank, the backend falls back to using VITE_SUPABASE_ANON_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Model Provider Config (Used only by Node Backend) ---
# CRITICAL: Keep these server-side to prevent exposing your private keys to users.
# You can configure one or both. The frontend lets users pick their preferred provider.
# If the selected provider is not configured, the backend auto-falls back to the other.
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# --- Express Server Config ---
PORT=5000
